{
  "name": "@neos/seo-intelligence",
  "version": "1.0.0",
  "description": "SEO Intelligence Engine (SIE) — evidence-based search opportunity detection and content recommendations for Northbridge products.",
  "private": true,
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "scripts": {
