# NEO connector credentials for org-northbridge-digital
#
# Copy this file to `.env` and fill in the values before running:
#   npm run neo:bootstrap
#
# These are read by scripts/bootstrap-neo.mjs to report which connector
# credentials are present vs. missing. NEVER commit real secrets — `.env`
# is gitignored. Values are never printed by the bootstrap script.

# OPTIONAL: repo-scoped read token used ONLY to clone the private NEO repo when
# the ambient git credentials / GitHub App installation cannot see it. Leave
# blank to rely on ambient git credentials. Never commit a real token.
NEO_REPO_TOKEN=

# Supabase project URL for the Northbridge Digital org connector
NEOS_ORG_NORTHBRIDGE_DIGITAL_CONNECTOR_SUPABASE_PROJECT_URL=

# Supabase service role key (secret) for the Northbridge Digital org connector
NEOS_ORG_NORTHBRIDGE_DIGITAL_CONNECTOR_SUPABASE_SERVICE_ROLE_KEY=

# GitHub access token for the Northbridge Digital org connector
NEOS_ORG_NORTHBRIDGE_DIGITAL_CONNECTOR_GITHUB_ACCESS_TOKEN=

# Vercel access token for the Northbridge Digital org connector
NEOS_ORG_NORTHBRIDGE_DIGITAL_CONNECTOR_VERCEL_ACCESS_TOKEN=
